
# Example of .env

# ── LLM provider ──────────────────────────────────────────────────────────────
# "lmstudio" (default) → local Gemma 4 via LM Studio
# "openai"             → remote OpenAI API
LLM_PROVIDER=lmstudio

# ── LM Studio (local) ─────────────────────────────────────────────────────────
# Check LM Studio → Local Server tab for the actual port (default 1234)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
# Must match exactly the model name shown in LM Studio's model loader
LM_STUDIO_MODEL=gemma-3-27b
# Any non-empty string works — LM Studio doesn't validate the key
LM_STUDIO_API_KEY=lm-studio

# ── OpenAI (only needed when LLM_PROVIDER=openai) ─────────────────────────────
# OPENAI_API_KEY=sk-...
# DEFAULT_OPENAI_MODEL=gpt-3.5-turbo

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Cohere (optional, Part 15 re-ranking only) ────────────────────────────────
# COHERE_API_KEY=

# ── Indexing defaults (optional overrides) ────────────────────────────────────
# CHUNK_SIZE=300
# CHUNK_OVERLAP=50
